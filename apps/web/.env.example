# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/recallai"

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Anthropic Claude API (required for AI card generation)
ANTHROPIC_API_KEY=""

# SMTP email (required for password reset emails)
# Leave blank to print reset links to the server console instead (dev mode)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="RecallAI <noreply@example.com>"
