# ── Database ──────────────────────────────────────────────────────────────────
# Set automatically by Vercel Neon integration (vercel.com → Storage → Neon Postgres)
DATABASE_URL=""

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Set to your Vercel deployment URL after first deploy, e.g. https://recallai.vercel.app
NEXTAUTH_URL=""

# ── Anthropic ─────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""

# ── Upstash Redis (REST) ───────────────────────────────────────────────────────
# upstash.com → Redis → your database → REST API tab
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Upstash QStash (serverless job queue) ─────────────────────────────────────
# upstash.com → QStash → API Keys
QSTASH_URL=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ── Cron jobs ─────────────────────────────────────────────────────────────────
# Random secret used to authenticate the daily digest cron endpoint.
# Generate: openssl rand -base64 32
# Set this as the Authorization: Bearer header when scheduling the QStash cron:
#   upstash.com → QStash → Schedules → Create  (cron: "0 8 * * *")
#   URL: https://your-domain.com/api/cron/daily-digest
#   Header: Authorization = Bearer <value>
CRON_SECRET=""

# ── Resend (transactional email) ──────────────────────────────────────────────
# resend.com → API Keys
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=""
# Your verified sender domain, e.g. RecallAI <noreply@yourdomain.com>
# Use <onboarding@resend.dev> for testing before domain is verified
SMTP_FROM="RecallAI <onboarding@resend.dev>"
