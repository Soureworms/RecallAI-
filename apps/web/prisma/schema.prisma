generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth / Org ──────────────────────────────────────────────────────────────

enum Role {
  AGENT
  MANAGER
  ADMIN
  SUPER_ADMIN
}

enum StudyMode {
  AUTO_ROTATE
  MANUAL
}

model Organization {
  id              String           @id @default(uuid())
  name            String
  studyMode       StudyMode        @default(AUTO_ROTATE)
  createdAt       DateTime         @default(now())
  teams           Team[]
  users           User[]
  decks           Deck[]
  sourceDocuments SourceDocument[]
}

model Team {
  id              String           @id @default(uuid())
  name            String
  orgId           String
  org             Organization     @relation(fields: [orgId], references: [id])
  members         TeamMember[]
  invites         Invite[]
  deckAssignments DeckAssignment[]
  createdAt       DateTime         @default(now())
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  name                 String?
  image                String?
  hashedPassword       String
  role                 Role                  @default(AGENT)
  orgId                String
  onboardedAt          DateTime?
  org                  Organization          @relation(fields: [orgId], references: [id])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  teams                TeamMember[]
  decks                Deck[]
  userCards            UserCard[]
  deckAssignments      DeckAssignment[]
  reviewLogs           ReviewLog[]
  sourceDocuments      SourceDocument[]
  invitesCreated       Invite[]
  passwordResetTokens  PasswordResetToken[]
  fsrsParameters       UserFSRSParameters?
  dailyRetentionRollups UserDailyRetentionRollup[]
  deckAssignmentsCreated DeckAssignment[]       @relation("DeckAssignmentAssignedBy")
}

model TeamMember {
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@id([userId, teamId])
}

// ─── Cards & Decks ───────────────────────────────────────────────────────────

enum CardFormat {
  QA
  TRUE_FALSE
  FILL_BLANK
}

enum CardStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Deck {
  id              String           @id @default(uuid())
  name            String
  description     String?
  orgId           String
  org             Organization     @relation(fields: [orgId], references: [id])
  isArchived      Boolean          @default(false)
  isMandatory     Boolean          @default(false)
  inRotation      Boolean          @default(true)
  createdById     String
  createdBy       User             @relation(fields: [createdById], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cards           Card[]
  assignments     DeckAssignment[]
  sourceDocuments SourceDocument[]
  assignments     DeckAssignment[]
}

model DeckAssignment {
  id         String   @id @default(uuid())
  deckId      String
  userId      String
  deck        Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt  DateTime @default(now())

  @@unique([deckId, userId])
  @@index([userId])
}

model Card {
  id               String          @id @default(uuid())
  deckId           String
  deck             Deck            @relation(fields: [deckId], references: [id])
  question         String
  answer           String
  format           CardFormat      @default(QA)
  tags             String[]
  difficulty       Int             @default(1)
  version          Int             @default(1)
  status           CardStatus      @default(DRAFT)
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  userCards        UserCard[]
  reviewLogs       ReviewLog[]

  @@index([deckId, status])
}


model DeckAssignment {
  userId       String
  deckId       String
  assignedById String?
  teamId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck       Deck  @relation(fields: [deckId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("DeckAssignmentAssignedBy", fields: [assignedById], references: [id])
  team       Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@id([userId, deckId])
  @@index([deckId])
  @@index([assignedById])
  @@index([teamId])
}

// ─── Source Documents ─────────────────────────────────────────────────────────

enum SourceDocumentStatus {
  PROCESSING
  READY
  ERROR
}

model SourceDocument {
  id           String               @id @default(uuid())
  orgId        String
  org          Organization         @relation(fields: [orgId], references: [id])
  filename     String
  mimeType     String
  sizeBytes    Int
  textContent  String
  contentHash  String
  status       SourceDocumentStatus @default(PROCESSING)
  uploadedById String
  uploadedBy   User                 @relation(fields: [uploadedById], references: [id])
  deckId       String?
  deck         Deck?                @relation(fields: [deckId], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  generationQuality Json?
  cards        Card[]
}

// ─── FSRS Scheduling ─────────────────────────────────────────────────────────

enum CardState {
  NEW
  LEARNING
  REVIEW
  RELEARNING
}

enum Rating {
  AGAIN
  HARD
  GOOD
  EASY
}

model UserCard {
  id             String    @id @default(uuid())
  userId         String
  cardId         String
  user           User      @relation(fields: [userId], references: [id])
  card           Card      @relation(fields: [cardId], references: [id])
  stability      Float     @default(0)
  difficulty     Float     @default(0)
  elapsedDays    Int       @default(0)
  scheduledDays  Int       @default(0)
  learningSteps  Int       @default(0)
  reps           Int       @default(0)
  lapses         Int       @default(0)
  state          CardState @default(NEW)
  dueDate        DateTime
  lastReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, cardId])
  @@index([userId, dueDate])
  @@index([cardId])
}

model ReviewLog {
  id                String    @id @default(uuid())
  userId            String
  cardId            String
  user              User      @relation(fields: [userId], references: [id])
  card              Card      @relation(fields: [cardId], references: [id])
  rating            Rating
  reviewedAt        DateTime  @default(now())
  scheduledInterval Float
  elapsedDays       Float
  stability         Float
  difficulty        Float
  state             CardState

  @@index([userId, reviewedAt])
  @@index([cardId, reviewedAt])
  @@index([reviewedAt])
  @@index([rating])
}

model UserDailyRetentionRollup {
  userId    String
  date      DateTime @db.Date
  retention Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
  @@index([date])
}

// ─── Invites ──────────────────────────────────────────────────────────────────

model Invite {
  id           String    @id @default(cuid())
  teamId       String
  team         Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  email        String
  role         Role
  token        String    @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdById  String
  createdBy    User      @relation(fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())
}

// ─── Per-user FSRS optimizer results ─────────────────────────────────────────

model UserFSRSParameters {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parameters          Json     // number[21] – optimized FSRS weights
  logLoss             Float?   // cross-entropy loss (lower = better fit)
  rmseBins            Float?   // RMSE across retention bins (lower = better)
  reviewCount         Int      @default(0)
  learningStepsSecs   Json?    // number[] – recommended learning step durations in seconds
  relearningStepsSecs Json?    // number[] – recommended relearning step durations in seconds
  lastOptimizedAt     DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model AIUsageEvent {
  id             String   @id @default(uuid())
  provider       String   @default("openai")
  model          String
  operation      String
  orgId          String?
  userId         String?
  deckId         String?
  sourceDocumentId String?
  requestId      String?
  promptTokens   Int      @default(0)
  completionTokens Int    @default(0)
  totalTokens    Int      @default(0)
  inputCostUsd   Decimal? @db.Decimal(12, 6)
  outputCostUsd  Decimal? @db.Decimal(12, 6)
  totalCostUsd   Decimal? @db.Decimal(12, 6)
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([provider, model, createdAt])
  @@index([orgId, createdAt])
  @@index([userId, createdAt])
  @@index([deckId, createdAt])
}
