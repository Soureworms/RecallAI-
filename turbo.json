{
  "$schema": "./node_modules/turbo/schema.json",
  "globalDependencies": [
    "pnpm-lock.yaml",
    "package.json",
    "biome.json",
    ".github/actions/**",
    ".github/workflows/**"
  ],
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "web#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "passThroughEnv": [
        "DATABASE_URL",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "ANTHROPIC_API_KEY",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "QSTASH_URL",
        "QSTASH_TOKEN",
        "QSTASH_CURRENT_SIGNING_KEY",
        "QSTASH_NEXT_SIGNING_KEY",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_USER",
        "SMTP_PASS",
        "SMTP_FROM",
        "POSTGRES_PRISMA_URL",
        "POSTGRES_URL",
        "POSTGRES_URL_NON_POOLING",
        "POSTGRES_URL_NO_SSL",
        "POSTGRES_USER",
        "POSTGRES_PASSWORD",
        "POSTGRES_HOST",
        "POSTGRES_DATABASE",
        "PGHOST",
        "PGHOST_UNPOOLED",
        "PGUSER",
        "PGPASSWORD",
        "PGDATABASE",
        "DATABASE_URL_UNPOOLED",
        "NEON_PROJECT_ID"
      ]
    },
    "@open-spaced-repetition/binding#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["NAPI_TARGET"],
      "passThroughEnv": ["ANDROID_NDK_LATEST_HOME"]
    },
    "check": {
      "outputs": [],
      "env": ["TURBO_PLATFORM"]
    },
    "check:fix": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": ["TURBO_PLATFORM"]
    },
    "@open-spaced-repetition/binding-test#test": {
      "dependsOn": ["@open-spaced-repetition/binding#build:dynamic"],
      "outputs": []
    },
    "@open-spaced-repetition/binding#build:dynamic": {
      "outputs": [
        "dist/dynamic-wasi.cjs",
        "dist/dynamic-wasi-browser.js",
        "dist/dynamic-wasi.d.ts"
      ]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["TURBO_PLATFORM"]
    },
    "@open-spaced-repetition/binding-test#test:coverage": {
      "dependsOn": ["@open-spaced-repetition/binding#build:dynamic"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs": {
      "dependsOn": ["build"],
      "outputs": ["../../docs/**"]
    }
  }
}
