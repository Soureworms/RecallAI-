# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/recallai"

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Anthropic Claude API (required for AI card generation)
ANTHROPIC_API_KEY=""

# Redis — required for the async job queue and distributed rate limiting
# Local dev: docker run -d -p 6379:6379 redis:7-alpine
# Production: use Upstash (rediss://...) or Railway Redis
REDIS_URL="redis://localhost:6379"

# SMTP email (required for password reset emails)
# Leave blank to print reset links to the server console instead (dev mode)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="RecallAI <noreply@example.com>"
