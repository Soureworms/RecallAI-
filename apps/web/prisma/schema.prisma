generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth / Org ──────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  AGENT
}

model Organization {
  id              String           @id @default(uuid())
  name            String
  createdAt       DateTime         @default(now())
  teams           Team[]
  users           User[]
  decks           Deck[]
  sourceDocuments SourceDocument[]
}

model Team {
  id      String       @id @default(uuid())
  name    String
  orgId   String
  org     Organization @relation(fields: [orgId], references: [id])
  members TeamMember[]
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  name            String?
  hashedPassword  String
  role            Role             @default(AGENT)
  orgId           String
  org             Organization     @relation(fields: [orgId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  teams           TeamMember[]
  decks           Deck[]
  userCards       UserCard[]
  reviewLogs      ReviewLog[]
  sourceDocuments SourceDocument[]
}

model TeamMember {
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@id([userId, teamId])
}

// ─── Cards & Decks ───────────────────────────────────────────────────────────

enum CardFormat {
  QA
  TRUE_FALSE
  FILL_BLANK
}

enum CardStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Deck {
  id              String           @id @default(uuid())
  name            String
  description     String?
  orgId           String
  org             Organization     @relation(fields: [orgId], references: [id])
  isArchived      Boolean          @default(false)
  isMandatory     Boolean          @default(false)
  createdById     String
  createdBy       User             @relation(fields: [createdById], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cards           Card[]
  sourceDocuments SourceDocument[]
}

model Card {
  id               String          @id @default(uuid())
  deckId           String
  deck             Deck            @relation(fields: [deckId], references: [id])
  question         String
  answer           String
  format           CardFormat      @default(QA)
  tags             String[]
  difficulty       Int             @default(1)
  version          Int             @default(1)
  status           CardStatus      @default(DRAFT)
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  userCards        UserCard[]
  reviewLogs       ReviewLog[]
}

// ─── Source Documents ─────────────────────────────────────────────────────────

enum SourceDocumentStatus {
  PROCESSING
  READY
  ERROR
}

model SourceDocument {
  id           String               @id @default(uuid())
  orgId        String
  org          Organization         @relation(fields: [orgId], references: [id])
  filename     String
  mimeType     String
  sizeBytes    Int
  textContent  String
  contentHash  String
  status       SourceDocumentStatus @default(PROCESSING)
  uploadedById String
  uploadedBy   User                 @relation(fields: [uploadedById], references: [id])
  deckId       String?
  deck         Deck?                @relation(fields: [deckId], references: [id])
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  cards        Card[]
}

// ─── FSRS Scheduling ─────────────────────────────────────────────────────────

enum CardState {
  NEW
  LEARNING
  REVIEW
  RELEARNING
}

enum Rating {
  AGAIN
  HARD
  GOOD
  EASY
}

model UserCard {
  id             String    @id @default(uuid())
  userId         String
  cardId         String
  user           User      @relation(fields: [userId], references: [id])
  card           Card      @relation(fields: [cardId], references: [id])
  stability      Float     @default(0)
  difficulty     Float     @default(0)
  elapsedDays    Int       @default(0)
  scheduledDays  Int       @default(0)
  learningSteps  Int       @default(0)
  reps           Int       @default(0)
  lapses         Int       @default(0)
  state          CardState @default(NEW)
  dueDate        DateTime
  lastReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, cardId])
}

model ReviewLog {
  id                String    @id @default(uuid())
  userId            String
  cardId            String
  user              User      @relation(fields: [userId], references: [id])
  card              Card      @relation(fields: [cardId], references: [id])
  rating            Rating
  reviewedAt        DateTime  @default(now())
  scheduledInterval Float
  elapsedDays       Float
  stability         Float
  difficulty        Float
  state             CardState
}
